# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
pnpm-debug.log*

# Build outputs
dist/
build/
*.tgz

# Environment variables
.env
.env.local
.env.*.local

# Logs (top-level only, not component directories)
/logs/
*.log

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.swp

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.bak

# Production data (should not be in repo)
/backups/
/data/

# Monitoring runtime data
monitoring/prometheus_data/*
!monitoring/prometheus_data/.gitkeep
monitoring/grafana_data/*
!monitoring/grafana_data/.gitkeep

# GenieACS runtime data
genieacs/logs/*
!genieacs/logs/.gitkeep
genieacs/ext/*
!genieacs/ext/.gitkeep

# SAS TLS certificates (auto-generated at startup, never commit)
nginx/certs/*.crt
nginx/certs/*.key
nginx/certs/*.pem

# Internal documentation (keep local)
GIT_PUSH_COMMANDS.md

# Local archive folder
docs/archive/
